# Copy this file to `.env` and fill in your values. `.env` is git-ignored.
#
# Crawlr runs fully offline with zero keys (heuristic mode). Setting an LLM
# provider below is OPTIONAL and only improves selector accuracy on unusual sites.

# LLM provider: openai | anthropic | none (default)
CRAWLR_LLM_PROVIDER=none

# API key for the chosen provider (leave blank for none)
CRAWLR_LLM_API_KEY=

# Optional model override (e.g. gpt-4o-mini for OpenAI)
CRAWLR_LLM_MODEL=

# --- Optional fetch tuning ---
# CRAWLR_DATA_DIR=./.crawlr
# CRAWLR_USER_AGENT=Mozilla/5.0 (compatible; Crawlr/0.1; +https://example.com/bot)
# CRAWLR_FETCH_TIMEOUT=30
# CRAWLR_FETCH_RETRIES=3
# CRAWLR_MIN_DELAY=1.0
